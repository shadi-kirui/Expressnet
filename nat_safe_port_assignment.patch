+@csrf_exempt
+@api_view(["GET"])
+def router_agent_poll(request, token):
+    """Polled every 30s by the router's own scheduler (set up during
+    provisioning). Returns a RouterOS script for the oldest pending command,
+    if any, so config changes reach the router without needing any inbound
+    connection to it."""
+    try:
+        tenant_id = _decode_agent_token(token)
+    except Exception:
+        return HttpResponse(':log warning "Billing SaaS: invalid agent token";\n', status=401, content_type="text/plain")
+
+    tenant = Tenant.objects.filter(pk=tenant_id).first()
+    if not tenant:
+        return HttpResponse(':log warning "Billing SaaS: tenant not found";\n', status=404, content_type="text/plain")
+
+    client_ip = (
+        request.META.get("HTTP_NGROK_AGENT_IPS")
+        or request.META.get("HTTP_X_FORWARDED_FOR")
+        or request.META.get("REMOTE_ADDR")
+        or ""
+    ).split(",")[0].strip()
+    ref(f"tenants/{tenant_id}").update({"mikrotik_last_seen_at": iso_now(), "mikrotik_last_seen_ip": client_ip})
+
+    commands = list((tenant.extra or {}).get("pending_router_commands") or [])
+    pending = next((c for c in commands if c.get("status") == "pending"), None)
+    if not pending:
+        return HttpResponse(':log info "Billing SaaS: no pending commands";\n', content_type="text/plain")
+
+    base_url = public_base_url(request).rstrip("/")
+    ack_url = f"{base_url}/api/router/agent/{token}/ack/{pending['id']}"
+    body_script = pending.get("script") or ""
+    script = f'{body_script} :do {{ /tool fetch url="{ack_url}" keep-result=no }} on-error={{}};\n'
+    return HttpResponse(script, content_type="text/plain")
+
+
+@csrf_exempt
+@api_view(["GET"])
+def router_agent_ack(request, token, command_id):
+    try:
+        tenant_id = _decode_agent_token(token)
+    except Exception:
+        return ok({"message": "Invalid agent token"}, 401)
+
+    tenant = Tenant.objects.filter(pk=tenant_id).first()
+    if not tenant:
+        return ok({"message": "Tenant not found"}, 404)
+
+    commands = list((tenant.extra or {}).get("pending_router_commands") or [])
+    for cmd in commands:
+        if cmd.get("id") == command_id:
+            cmd["status"] = "applied"
+            cmd["applied_at"] = iso_now()
+
+    assignments = dict(tenant.extra.get("router_port_assignments") or {}) if tenant.extra else {}
+    applied = next((c for c in commands if c.get("id") == command_id), None)
+    if applied and applied.get("interface") in assignments:
+        assignments[applied["interface"]]["status"] = "applied"
+
+    ref(f"tenants/{tenant_id}").update({
+        "pending_router_commands": commands,
+        "router_port_assignments": assignments,
+        "mikrotik_last_seen_at": iso_now(),
+    })
+    return ok({"success": True})
+
