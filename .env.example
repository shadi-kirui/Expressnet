DJANGO_SETTINGS_MODULE=billing_saas_django.Settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
CSRF_TRUSTED_ORIGINS=

API_BASE_PATH=api
ADMIN_API_PATH=admin
ADMIN_FRONTEND_PATH=admin
VITE_API_BASE_URL=/api
VITE_ADMIN_PATH=/admin
VITE_ADMIN_API_PATH=/admin

# Railway deploys should use the private URL from the Postgres service:
# DATABASE_URL=postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}
#
# Local development cannot reach RAILWAY_PRIVATE_DOMAIN. Use Railway's public
# TCP proxy values here when connecting from your machine:
# DATABASE_PUBLIC_URL=postgresql://postgres:<url-encoded-password>@<RAILWAY_TCP_PROXY_DOMAIN>:<RAILWAY_TCP_PROXY_PORT>/railway
DATABASE_URL=
DATABASE_PUBLIC_URL=
DATABASE_SSL_REQUIRE=true
REDIS_URL=redis://localhost:6379/0

DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
DJANGO_SUPERUSER_NAME=Super Admin
